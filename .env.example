# Base de données
DATABASE_URL=postgresql://saas_user:saas_secret@localhost:5432/saas_erp

# Cache & Queue
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# Auth
JWT_SECRET=change_me_in_production_min_32_chars_please
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

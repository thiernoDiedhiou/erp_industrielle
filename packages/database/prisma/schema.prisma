datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

// ═══════════════════════════════════════════════════════
// SUPER ADMINS — Équipe Innosoft (cross-tenant)
// ═══════════════════════════════════════════════════════
model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  nom          String
  actif        Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt      @map("updated_at")

  @@map("super_admins")
}

// ═══════════════════════════════════════════════════════
// TENANTS — Entreprises clientes de la plateforme
// ═══════════════════════════════════════════════════════
model Tenant {
  id                String   @id @default(uuid())
  slug              String   @unique
  nom               String
  secteur           String
  plan              String   @default("starter")
  actif             Boolean  @default(true)     @map("is_active")
  logo              String?                      @map("logo_url")
  couleurPrimaire   String?                      @map("couleur_primaire")
  couleurSecondaire String?                      @map("couleur_secondaire")
  telephone         String?
  adresse           String?
  ville             String?
  pays              String   @default("SN")
  createdAt         DateTime @default(now())    @map("created_at")
  updatedAt         DateTime @updatedAt         @map("updated_at")

  users         User[]
  groupes       Groupe[]
  tenantModules TenantModule[]
  settings      Setting[]
  customFields  CustomField[]
  customEnums   CustomEnum[]
  workflows     WorkflowDefinition[]

  @@map("tenants")
}

// ═══════════════════════════════════════════════════════
// MODULES — Fonctionnalités activables par tenant
// ═══════════════════════════════════════════════════════
model Module {
  id          String @id @default(uuid())
  code        String @unique
  nom         String
  description String
  icon        String?

  tenantModules TenantModule[]

  @@map("modules")
}

model TenantModule {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  moduleId    String   @map("module_id")
  actif       Boolean  @default(true) @map("is_active")
  config      Json?
  activatedAt DateTime @default(now()) @map("activated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  module Module @relation(fields: [moduleId], references: [id])

  @@unique([tenantId, moduleId])
  @@map("tenant_modules")
}

// ═══════════════════════════════════════════════════════
// SETTINGS — Configuration clé/valeur par tenant
// ═══════════════════════════════════════════════════════
model Setting {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  cle      String @map("key")
  valeur   String @map("value")
  type     String @default("string")
  label    String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, cle], map: "settings_tenant_id_key_unique")
  @@map("settings")
}

// ═══════════════════════════════════════════════════════
// CUSTOM FIELDS — Champs dynamiques sans code
// ═══════════════════════════════════════════════════════
model CustomField {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  entite      String  @map("entity")
  nom         String  @map("code")
  label       String
  type        String  @map("field_type")
  obligatoire Boolean @default(false) @map("required")
  options     Json?
  ordre       Int     @default(0)     @map("sort_order")
  actif       Boolean @default(true)  @map("is_active")

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  valeurs CustomFieldValue[]

  @@unique([tenantId, entite, nom])
  @@map("custom_fields")
}

model CustomFieldValue {
  id       String @id @default(uuid())
  champId  String @map("custom_field_id")
  entiteId String @map("entity_id")
  entite   String
  tenantId String @map("tenant_id")
  valeur   String @map("value")

  champ CustomField @relation(fields: [champId], references: [id])

  @@unique([champId, entiteId], map: "custom_field_values_field_entity_unique")
  @@map("custom_field_values")
}

// ═══════════════════════════════════════════════════════
// CUSTOM ENUMS — Listes de valeurs configurables
// ═══════════════════════════════════════════════════════
model CustomEnum {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  entite   String  @map("entity")
  code     String  @map("value")
  libelle  String  @map("label")
  couleur  String? @map("color")
  ordre    Int     @default(0)    @map("sort_order")
  actif    Boolean @default(true) @map("is_active")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, entite, code])
  @@map("custom_enums")
}

// ═══════════════════════════════════════════════════════
// WORKFLOWS — Processus configurables par tenant
// ═══════════════════════════════════════════════════════
model WorkflowDefinition {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  entite    String   @map("entity")
  nom       String
  actif     Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  etats       WorkflowState[]
  transitions WorkflowTransition[]

  @@map("workflow_definitions")
}

model WorkflowState {
  id         String  @id @default(uuid())
  workflowId String  @map("workflow_id")
  code       String
  libelle    String  @map("label")
  couleur    String? @map("color")
  etapInitiale Boolean @default(false) @map("is_initial")
  etapFinale   Boolean @default(false) @map("is_final")
  ordre      Int     @default(0) @map("sort_order")

  workflow         WorkflowDefinition   @relation(fields: [workflowId], references: [id])
  transitionsDepart WorkflowTransition[] @relation("FromState")
  transitionsArrivee WorkflowTransition[] @relation("ToState")

  @@unique([workflowId, code])
  @@map("workflow_states")
}

model WorkflowTransition {
  id             String   @id @default(uuid())
  workflowId     String   @map("workflow_id")
  etatSourceId   String   @map("from_state_id")
  etatCibleId    String   @map("to_state_id")
  libelle        String   @map("label")
  rolesAutorises String[] @map("roles_allowed")
  needsApproval  Boolean  @default(false) @map("needs_approval")

  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id])
  etatSource WorkflowState      @relation("FromState", fields: [etatSourceId], references: [id])
  etatCible  WorkflowState      @relation("ToState", fields: [etatCibleId], references: [id])

  @@map("workflow_transitions")
}

// ═══════════════════════════════════════════════════════
// USERS
// ═══════════════════════════════════════════════════════
model User {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  nom               String
  prenom            String?
  email             String
  passwordHash      String    @map("password_hash")
  refreshTokenHash  String?   @map("refresh_token_hash")
  role              String
  telephone         String?
  actif             Boolean   @default(true)  @map("is_active")
  derniereConnexion DateTime?                  @map("last_login")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt      @map("updated_at")
  deletedAt         DateTime?                  @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ═══════════════════════════════════════════════════════
// GROUPES & PERMISSIONS (dynamiques par tenant)
// ═══════════════════════════════════════════════════════
model Groupe {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  code        String   // correspond au UserRole : admin | direction | commercial | ...
  nom         String
  description String?
  // JSON : { crm: { lire: true, ecrire: true, supprimer: false }, commandes: {...}, ... }
  permissions Json     @default("{}")
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("groupes")
}

// ═══════════════════════════════════════════════════════
// CRM — Clients et Produits
// ═══════════════════════════════════════════════════════
model Client {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  nom             String    @map("nom_entreprise")
  reference       String    @map("code_client")
  type            String    @default("entreprise") @map("type_client")
  ninea           String?
  adresse         String?
  ville           String?
  telephone       String?
  email           String?
  // Nouveaux champs
  contact         String?   @map("contact_principal")     // Nom du contact commercial
  commercialId    String?   @map("commercial_id")         // Responsable commercial (userId)
  plafondCredit   Decimal?  @db.Decimal(15, 2) @map("plafond_credit")    // Plafond de crédit XOF
  delaiPaiement   Int?      @map("delai_paiement")        // Délai de paiement en jours
  statut          String    @default("actif")
  metadonnees     Json?     @map("metadonnees")               // Champs personnalisés tenant
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")
  deletedAt       DateTime?                  @map("deleted_at")

  commandes     Commande[]
  bonsLivraison BonLivraison[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@map("clients")
}

model Produit {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  reference       String    @map("code_produit")
  nom             String    @map("designation")
  categorie       String
  unite           String    @default("pce") @map("unite_mesure")
  prixUnitaire    Decimal   @default(0) @db.Decimal(15, 2) @map("prix_vente_ht")
  // Nouveaux champs
  coutProduction  Decimal?  @db.Decimal(15, 2) @map("cout_production")   // Coût de production estimé
  poidsUnite      Decimal?  @db.Decimal(10, 3) @map("poids_unite")        // Poids unitaire en kg
  stockMin        Decimal   @default(0) @db.Decimal(10, 2) @map("stock_min")  // Seuil d'alerte stock
  stockActuel     Decimal   @default(0) @db.Decimal(10, 2) @map("stock_actuel") // Quantité en stock
  description     String?   @map("description_technique")
  metadonnees     Json?     @map("metadonnees")               // Champs personnalisés tenant
  actif           Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt      @map("updated_at")
  deletedAt       DateTime?                  @map("deleted_at")

  lignes          LigneCommande[]
  ofs             OrdreFabrication[]
  lignesLivraison LigneLivraison[]
  boms            BomItem[]
  bomsComme       Bom[]            @relation("BomProduitFini")
  mouvements      MouvementStock[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@map("produits")
}

// ═══════════════════════════════════════════════════════
// BOM — Nomenclature produits (Bill of Materials)
// ═══════════════════════════════════════════════════════
model Bom {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  nom         String
  produitFiniId String @map("produit_fini_id")  // Produit fabriqué
  version     String   @default("1.0")
  actif       Boolean  @default(true) @map("is_active")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  produitFini Produit? @relation("BomProduitFini", fields: [produitFiniId], references: [id])
  items       BomItem[]

  @@unique([tenantId, produitFiniId, version])
  @@index([tenantId])
  @@map("boms")
}

model BomItem {
  id                String  @id @default(uuid())
  bomId             String  @map("bom_id")
  matierePremiereId String? @map("matiere_premiere_id") // MP utilisée
  produitId         String? @map("produit_id")          // Ou produit semi-fini
  quantite          Decimal @db.Decimal(10, 3)
  unite             String  @default("kg") @map("unite_mesure")
  pertes            Decimal @default(0) @db.Decimal(5, 2) @map("taux_pertes_pct") // % de pertes
  notes             String?

  bom             Bom              @relation(fields: [bomId], references: [id], onDelete: Cascade)
  matierePremiere MatierePremiere? @relation(fields: [matierePremiereId], references: [id])
  produit         Produit?         @relation(fields: [produitId], references: [id])

  @@map("bom_items")
}

// ═══════════════════════════════════════════════════════
// COMMANDES
// ═══════════════════════════════════════════════════════
model Commande {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  reference             String    @map("numero_commande")
  clientId              String    @map("client_id")
  statut                String    @default("brouillon")
  dateLivraison         DateTime? @map("date_livraison_souhaitee")
  dateLivraisonPrevue   DateTime? @map("date_livraison_prevue")  // Confirmée par production
  adresseLivraison      String?   @map("adresse_livraison")
  commercialId          String?   @map("commercial_id")           // User responsable
  totalHT               Decimal   @default(0) @db.Decimal(15, 2) @map("montant_ht")
  tva                   Decimal   @default(0) @db.Decimal(15, 2)
  totalTTC              Decimal   @default(0) @db.Decimal(15, 2) @map("montant_ttc")
  notes                 String?
  metadonnees           Json?     @map("metadonnees")          // Champs personnalisés tenant
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt      @map("updated_at")
  deletedAt             DateTime?                  @map("deleted_at")

  client             Client               @relation(fields: [clientId], references: [id])
  lignes             LigneCommande[]
  historique         CommandeHistorique[]
  factures           Facture[]
  bonsLivraison      BonLivraison[]
  ordresFabrication  OrdreFabrication[]

  @@unique([tenantId, reference])
  @@index([tenantId, statut])
  @@map("commandes")
}

model LigneCommande {
  id           String  @id @default(uuid())
  commandeId   String  @map("commande_id")
  produitId    String  @map("produit_id")
  quantite     Decimal @db.Decimal(10, 2)
  prixUnitaire Decimal @db.Decimal(15, 2) @map("prix_unitaire_ht")
  remise       Decimal @default(0) @db.Decimal(5, 2) @map("remise_pct")  // Remise %
  montant      Decimal @db.Decimal(15, 2) @map("montant_ligne_ht")
  description  String?

  commande Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit  Produit  @relation(fields: [produitId], references: [id])

  @@map("lignes_commande")
}

model CommandeHistorique {
  id            String   @id @default(uuid())
  commandeId    String   @map("commande_id")
  tenantId      String   @map("tenant_id")
  userId        String   @map("user_id")
  ancienStatut  String?  @map("from_statut")
  nouveauStatut String   @map("to_statut")
  commentaire   String?
  createdAt     DateTime @default(now()) @map("created_at")

  commande Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)

  @@map("commande_historique")
}

// ═══════════════════════════════════════════════════════
// FOURNISSEURS
// ═══════════════════════════════════════════════════════
model Fournisseur {
  id                  String    @id @default(uuid())
  tenantId            String    @map("tenant_id")
  reference           String    @map("code_fournisseur")
  nom                 String    @map("nom_entreprise")
  pays                String    @default("SN")
  contact             String?   @map("contact_principal")       // Nom du contact commercial
  email               String?
  telephone           String?
  // Nouveaux champs
  delaiLivraisonMoyen Int?      @map("delai_livraison_moyen")   // Délai moyen en jours
  noteEvaluation      Decimal?  @db.Decimal(3, 1) @map("note_evaluation")  // Note 0-10
  conditionsPaiement  String?   @map("conditions_paiement")
  actif               Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt      @map("updated_at")
  deletedAt           DateTime?                  @map("deleted_at")

  matieresPrmieres MatierePremiere[]

  @@unique([tenantId, reference])
  @@map("fournisseurs")
}

// ═══════════════════════════════════════════════════════
// MATIÈRES PREMIÈRES
// ═══════════════════════════════════════════════════════
model MatierePremiere {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  reference             String    @map("code_mp")
  nom                   String    @map("designation")
  type                  String    @map("type_mp")
  fournisseurId         String?   @map("fournisseur_id")
  unite                 String    @default("kg") @map("unite_mesure")
  prixAchat             Decimal   @default(0) @db.Decimal(15, 2) @map("prix_achat_unitaire")
  stockActuel           Decimal   @default(0) @db.Decimal(10, 2) @map("stock_actuel")
  stockMinimum          Decimal   @default(0) @db.Decimal(10, 2) @map("stock_minimum")
  // Nouveau champ
  delaiApprovisionnement Int?     @map("delai_approvisionnement") // Délai en jours
  isRecycle             Boolean   @default(false) @map("is_recycle")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt      @map("updated_at")
  deletedAt             DateTime?                  @map("deleted_at")

  fournisseur   Fournisseur?  @relation(fields: [fournisseurId], references: [id])
  consommations ConsommationMP[]
  mouvements    MouvementStock[]
  bomItems      BomItem[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@map("matieres_premieres")
}

// ═══════════════════════════════════════════════════════
// MACHINES
// ═══════════════════════════════════════════════════════
model Machine {
  id                      String    @id @default(uuid())
  tenantId                String    @map("tenant_id")
  code                    String
  nom                     String    @map("nom_machine")
  type                    String    @map("type_machine")
  statut                  String    @default("disponible")
  capacite                Decimal?  @db.Decimal(10, 2) @map("capacite_production")
  unite                   String?
  // Nouveaux champs
  localisation            String?   @map("localisation")              // Zone / atelier
  dateDerniereMaintenance DateTime? @map("date_derniere_maintenance")
  prochaineMaintenanceDate DateTime? @map("prochaine_maintenance_date")
  metadonnees             Json?     @map("metadonnees")        // Champs personnalisés tenant
  actif                   Boolean   @default(true) @map("is_active")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt      @map("updated_at")
  deletedAt               DateTime?                  @map("deleted_at")

  ofs OrdreFabrication[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("machines")
}

// ═══════════════════════════════════════════════════════
// ORDRES DE FABRICATION
// ═══════════════════════════════════════════════════════
model OrdreFabrication {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  reference        String    @map("numero_of")
  commandeId       String?   @map("commande_id")
  produitId        String    @map("produit_id")
  produitFini      String    @map("produit_fini")
  quantitePrevue   Decimal   @db.Decimal(10, 2) @map("quantite_prevue")
  quantiteProduite Decimal   @default(0) @db.Decimal(10, 2) @map("quantite_produite")
  // Nouveaux champs
  quantiteRebut    Decimal   @default(0) @db.Decimal(10, 2) @map("quantite_rebut")  // Quantité rebutée
  dateDebutPrevue  DateTime? @map("date_debut_prevue")    // Date de début planifiée
  dateFinPrevue    DateTime? @map("date_fin_prevue")      // Date de fin planifiée
  statut           String    @default("planifie")
  machineId        String?   @map("machine_id")
  dateDebut        DateTime? @map("date_debut_reelle")    // Date réelle de début
  dateFin          DateTime? @map("date_fin_reelle")      // Date réelle de fin
  notes            String?   @map("notes_production")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  machine       Machine?       @relation(fields: [machineId], references: [id])
  produit       Produit        @relation(fields: [produitId], references: [id])
  commande      Commande?      @relation(fields: [commandeId], references: [id])
  consommations ConsommationMP[]

  @@unique([tenantId, reference])
  @@index([tenantId, statut])
  @@map("ordres_fabrication")
}

model ConsommationMP {
  id                  String   @id @default(uuid())
  ordreFabricationId  String   @map("of_id")
  matierePremiereId   String   @map("matiere_id")
  tenantId            String   @map("tenant_id")
  quantiteConsommee   Decimal  @db.Decimal(10, 2) @map("quantite_reelle")

  of              OrdreFabrication @relation(fields: [ordreFabricationId], references: [id], onDelete: Cascade)
  matierePremiere MatierePremiere  @relation(fields: [matierePremiereId], references: [id])

  @@map("consommations_mp")
}

// ═══════════════════════════════════════════════════════
// MOUVEMENTS DE STOCK
// ═══════════════════════════════════════════════════════
model MouvementStock {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  type              String   @map("type_mouvement")
  reference         String   @map("reference_document")
  matierePremiereId String?  @map("matiere_id")
  produitId         String?  @map("produit_id")
  fournisseurId     String?  @map("fournisseur_id")
  quantite          Decimal  @db.Decimal(10, 2)
  motif             String?
  createdAt         DateTime @default(now()) @map("created_at")

  matierePremiere MatierePremiere? @relation(fields: [matierePremiereId], references: [id])
  produit         Produit?         @relation(fields: [produitId], references: [id])

  @@index([tenantId])
  @@map("mouvements_stock")
}

// ═══════════════════════════════════════════════════════
// FACTURATION
// ═══════════════════════════════════════════════════════
model Facture {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  reference    String    @map("numero_facture")
  commandeId   String    @map("commande_id")
  statut       String    @default("emise")      @map("statut_paiement")
  totalHT      Decimal   @db.Decimal(15, 2)     @map("montant_ht")
  tva          Decimal   @db.Decimal(15, 2)     @map("montant_tva")
  totalTTC     Decimal   @db.Decimal(15, 2)     @map("montant_ttc")
  dateEcheance DateTime                          @map("date_echeance")
  pdfUrl       String?                           @map("pdf_url")
  createdAt    DateTime  @default(now())         @map("created_at")
  deletedAt    DateTime?                          @map("deleted_at")

  commande  Commande   @relation(fields: [commandeId], references: [id])
  paiements Paiement[]

  @@unique([tenantId, reference])
  @@map("factures")
}

model Paiement {
  id           String   @id @default(uuid())
  factureId    String   @map("facture_id")
  tenantId     String   @map("tenant_id")
  montant      Decimal  @db.Decimal(15, 2)
  mode         String   @map("mode_paiement")  // especes | virement | cheque | mobile_money
  reference    String?  @map("reference_transaction")
  notes        String?
  datePaiement DateTime @default(now()) @map("date_paiement")

  facture Facture @relation(fields: [factureId], references: [id])

  @@map("paiements")
}

// ═══════════════════════════════════════════════════════
// LOGISTIQUE — Bons de livraison
// ═══════════════════════════════════════════════════════
model BonLivraison {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  reference        String    @map("numero_bl")
  commandeId       String?   @map("commande_id")
  clientId         String    @map("client_id")
  statut           String    @default("prepare")  // prepare | expedie | livre | annule
  adresseLivraison String?   @map("adresse_livraison")
  transporteur     String?
  // Nouveaux champs
  chauffeur        String?   @map("chauffeur")    // Nom du chauffeur
  vehicule         String?   @map("vehicule")     // Immatriculation
  dateExpedition   DateTime? @map("date_expedition")
  dateLivraison    DateTime? @map("date_livraison_reelle")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt      @map("updated_at")

  lignes   LigneLivraison[]
  commande Commande?        @relation(fields: [commandeId], references: [id])
  client   Client           @relation(fields: [clientId], references: [id])

  @@unique([tenantId, reference])
  @@index([tenantId, statut])
  @@map("bons_livraison")
}

model LigneLivraison {
  id             String  @id @default(uuid())
  bonLivraisonId String  @map("bon_livraison_id")
  produitId      String  @map("produit_id")
  quantite       Decimal @db.Decimal(10, 2)
  description    String?

  bonLivraison BonLivraison @relation(fields: [bonLivraisonId], references: [id], onDelete: Cascade)
  produit      Produit      @relation(fields: [produitId], references: [id])

  @@map("lignes_livraison")
}

// ═══════════════════════════════════════════════════════
// AUDIT LOG — Traçabilité complète des actions
// ═══════════════════════════════════════════════════════
model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String?  @map("user_id")
  userEmail String?  @map("user_email")
  action    String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | EXPORT
  entite    String   @map("entity")
  entiteId  String?  @map("entity_id")
  avant     Json?    @map("before")
  apres     Json?    @map("after")
  ip        String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, entite, entiteId])
  @@index([tenantId, userId])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════
// RECYCLAGE (module optionnel)
// ═══════════════════════════════════════════════════════
model RecyclageCollecte {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  typeDechet   String   @map("type_dechet")
  quantite     Decimal  @db.Decimal(10, 2)  @map("quantite_kg")
  unite        String   @default("kg")
  sourceAdresse String? @map("source")
  collecteur   String?
  statut       String   @default("collecte")  // collecte | traitement | valorise
  notes        String?
  dateCollecte DateTime @default(now()) @map("date_collecte")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("recyclage_collectes")
}

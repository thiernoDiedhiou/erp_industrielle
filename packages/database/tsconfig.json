{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "types": ["node"],
    "typeRoots": ["../../node_modules/@types", "node_modules/@types"]
  },
  "include": ["prisma/**/*"],
  "exclude": ["node_modules", "dist"]
}
